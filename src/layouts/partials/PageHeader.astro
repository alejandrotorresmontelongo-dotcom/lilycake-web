---
import { humanize, markdownify } from "@/lib/utils/textConverter";

const {
  title = "",
  description = "",
  backgroundColor = "bg-primary/5",
  height = "h-[575px]",
}: {
  title?: string;
  description?: string;
  backgroundColor?: string;
  height?: string;
} = Astro.props;
---

<section class={`pt-20 ${backgroundColor} ${height}`}>
  <div class="container text-center">
    <div class="max-w-xl mx-auto text-balance">
      <h1
        class="xl:text-[100px] font-normal"
        set:text={humanize(title)}
        data-aos="fade-up-sm"
        data-aos-delay="100"
      />
      <p
        class="mt-4"
        data-aos="fade-up-sm"
        data-aos-delay="150"
        set:html={markdownify(description)}
      />
    </div>
  </div>
</section>
