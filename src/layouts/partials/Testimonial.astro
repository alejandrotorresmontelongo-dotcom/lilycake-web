---
import { markdownify } from "@/lib/utils/textConverter";
import ImageMod from "@/components/ImageMod.astro";
import { getListPage } from "@/lib/contentParser.astro";

const testimonial = await getListPage("testimonialSection", "testimonial");
---

{
  testimonial.data.enable && (
    <section class="section overflow-x-hidden">
      <div class="container">
        <div class="row">
          <div class="mx-auto mb-12 text-center md:col-10 lg:col-8 xl:col-6">
            <h2
              data-aos="fade-up-sm"
              data-aos-delay="100"
              set:html={markdownify(testimonial.data.title)}
              class="mb-4"
            />
            <a
  href="https://www.google.com/maps/place/lilycake/@25.7440295,-100.386257,3a,75y,236.78h,80.69t/data=!3m7!1e1!3m5!1sekQnSr7qw90fq2VXoks-VA!2e0!6shttps:%2F%2Fstreetviewpixels-pa.googleapis.com%2Fv1%2Fthumbnail%3Fcb_client%3Dmaps_sv.tactile%26w%3D900%26h%3D600%26pitch%3D9.310000000000002%26panoid%3DekQnSr7qw90fq2VXoks-VA%26yaw%3D236.78!7i16384!8i8192!4m7!3m6!1s0x866297b362a48a7b:0x27fc3c2d8f698126!8m2!3d25.7439747!4d-100.3863878!10e5!16s%2Fg%2F11nk7lf3hs?entry=ttu&g_ep=EgoyMDI2MDYwMS4wIKXMDSoASAFQAw%3D%3D"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-block mt-6 px-6 py-3 bg-white text-pink-600 rounded-lg font-semibold hover:bg-gray-100"
>
  ⭐ Ver todas las reseñas en Google Maps
</a>
          </div>
          <div class="col-12">
            <div class="swiper testimonial-slider swiper-container-equal-height">
              <div class="swiper-wrapper">
                {testimonial.data.testimonials.map((item) => (
                  <div class="swiper-slide rounded-xl bg-amber-200 px-8 py-10">
                    <div class="h-full flex flex-col">
                      <h6 class="text-secondary font-primary font-bold">
                        {item.title}
                      </h6>
                      <blockquote
                        class="mt-8 text-text/90 pb-6"
                        set:html={markdownify(item.content)}
                      />
                      <div class="flex items-center pt-6 mt-auto border-t border-border">
                        <ImageMod
                          height={70}
                          width={70}
                          class="rounded-full"
                          src={item.avatar}
                          alt={item.name}
                          format="webp"
                        />
                        <div class="ml-4">
                          <h3
                            set:text={item.name}
                            class="text-sm font-primary font-semibold mb-1"
                          />
                          <p set:text={item.address} class="text-sm" />
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="testimonial-slider-pagination mt-9 flex items-center justify-center text-center" />
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  import { Swiper } from "swiper";
  import "swiper/css";
  import "swiper/css/pagination";
  import { Autoplay, Pagination } from "swiper/modules";

  // astro:page-load event is fired when the page is loaded
  document.addEventListener("astro:page-load", () => {
    new Swiper(".testimonial-slider", {
      modules: [Pagination, Autoplay],
      spaceBetween: 24,
      loop: true,
      centeredSlides: true,
      autoplay: {
        delay: 2500,
        disableOnInteraction: false,
      },
      pagination: {
        el: ".testimonial-slider-pagination",
        type: "bullets",
        clickable: true,
      },
      autoHeight: false,
      watchSlidesProgress: true,
      breakpoints: {
        768: {
          slidesPerView: 2,
        },
        992: {
          slidesPerView: 3,
        },
      },
    });

    // Set equal heights for all slides
    const setEqualHeights = () => {
      const slides = document.querySelectorAll(
        ".testimonial-slider .swiper-slide"
      ) as NodeListOf<HTMLElement>;
      let maxHeight = 0;

      // Reset heights
      slides.forEach((slide) => {
        slide.style.height = "auto";
      });

      // Find max height
      slides.forEach((slide) => {
        const height = slide.offsetHeight;
        maxHeight = Math.max(maxHeight, height);
      });

      // Set equal height to all slides
      if (maxHeight > 0) {
        slides.forEach((slide) => {
          slide.style.height = `${maxHeight}px`;
        });
      }
    };

    // Set equal heights initially and on window resize
    setTimeout(setEqualHeights, 100);
    window.addEventListener("resize", setEqualHeights);
  });
</script>

<style>
  /* Ensure equal heights for testimonial slides */
  .swiper-container-equal-height .swiper-slide {
    height: auto !important;
  }

  @media (min-width: 768px) {
    .swiper-container-equal-height .swiper-wrapper {
      display: flex;
      align-items: stretch;
    }
  }
</style>
