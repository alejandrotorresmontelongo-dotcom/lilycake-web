---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";

const menu = await getListPage("menu", "-index");
if (menu.data.draft) {
  return Astro.redirect("/404");
}
const { title, description, foods, food_apps } = menu.data;

const groups = [
  ...new Set(foods.map((food) => food.group.toLocaleLowerCase())),
];
---

<Base {...menu.data}>
  <section class="section pt-16 xl:pt-20">
    <div class="container">
      <div class="row justify-center">
        <div class="md:col-8 sm:col-10 lg:col-6 text-center capitalize">
          <h1
            class="mb-6 xl:text-[100px] font-normal"
            set:html={markdownify(title)}
          />
          <p class="text-balance" set:html={markdownify(description)} />
        </div>
      </div>

      <!-- shuffle menus section  -->
      <div class="mt-6">
        

        <ul
          class="row justify-center gy-5 gx-4 shuffle-container mx-auto w-full"
        >
          {
            foods.map((item, i) => (
              <li
                data-groups={`["${item.group}","all"]`}
                data-aos="fade-up"
                data-aos-delay={(i + 1) * 50 + 100}
                class="col-12 sm:col-6 lg:col-3 mx-auto"
              >
                <div class="border border-border rounded-xl overflow-hidden max-w-xs mx-auto">
                  <ImageMod
                    src={item?.image}
                    alt={`member-${item.name}`}
                    class="h-[230px] w-full object-cover"
                    width={400}
                    height={300}
                    loading="lazy"
                  />
                  <div class="p-7 text-center">
                    <h4 class="text-white font-primary text-xl italic font-bold">
                      <span>{markdownify(item.currency)}</span>
                      {markdownify(item.price)}
                    </h4>
                    <h3
                      class="font-semibold text-lg font-primary my-4"
                      set:html={markdownify(item.name)}
                    />
                    <p
                      class="text-sm"
                      set:html={markdownify(item.description)}
                    />
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="section bg-primary/5">
    <div class="container">
      <div
        class="row items-center max-xl:justify-center max-xl:text-center g-4"
      >
        <div class="col-10 xl:col-4">
          <h2 class="mb-4" set:html={markdownify(food_apps?.title)} />
          <p
            class="text-sm text-text/90 text-balance"
            set:html={markdownify(food_apps?.description)}
          />
        </div>
        <div class="col-11 xl:col-8">
          <div class="space-y-6 md:space-y-8 max-xl:mt-10">
            {/* First row - closer spacing */}
            <div
              class="flex flex-wrap justify-center items-center gap-3 md:gap-5"
            >
              {
                food_apps?.images
                  .slice(0, 3)
                  .map((image, i) => (
                    <ImageMod
                      src={image}
                      alt={`food-app-${i}`}
                      class="rounded-lg object-cover w-[30%] sm:w-[150px] md:w-[180px] xl:w-[222px]"
                      width={222}
                      height={91}
                      style="box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05), 0 2px 30px rgba(0, 0, 0, 0.05);"
                    />
                  ))
              }
            </div>

            {/* Middle row - regular spacing */}
            <div
              class="flex flex-wrap justify-center items-center gap-3 md:gap-5"
            >
              {
                food_apps?.images
                  .slice(3, 6)
                  .map((image, i) => (
                    <ImageMod
                      src={image}
                      alt={`food-app-${i + 3}`}
                      class="rounded-lg object-cover w-[30%] sm:w-[150px] md:w-[200px] lg:w-[255px]"
                      width={255}
                      height={91}
                      style="box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05), 0 2px 30px rgba(0, 0, 0, 0.05);"
                    />
                  ))
              }
            </div>

            {/* Last row - closer spacing */}
            <div
              class="flex flex-wrap justify-center items-center gap-3 md:gap-5"
            >
              {
                food_apps?.images
                  .slice(6, 9)
                  .map((image, i) => (
                    <ImageMod
                      src={image}
                      alt={`food-app-${i + 6}`}
                      class="rounded-lg object-cover w-[30%] sm:w-[150px] md:w-[180px] xl:w-[222px]"
                      width={222}
                      height={91}
                      style="box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05), 0 2px 30px rgba(0, 0, 0, 0.05);"
                    />
                  ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import Shuffle from "shufflejs";

  document.addEventListener("astro:page-load", () => {
    var element = document.querySelector(".shuffle-container");
    var shuffleInstance = new Shuffle(element as HTMLElement, {
      itemSelector: "li",
    });

    var filterItems = document.querySelectorAll(".shuffle-filter li");
    filterItems.forEach(function (item) {
      item.addEventListener("click", function (this: HTMLElement, e) {
        e.preventDefault();

        filterItems.forEach(function (item) {
          // Remove active state from all buttons
          item.classList.remove("bg-secondary");
          item.classList.remove("text-white");
          item.classList.add("hover:bg-secondary");
          item.classList.add("hover:text-white");
        });

        // Add active state to clicked button
        this.classList.add("bg-secondary");
        this.classList.add("text-white");
        this.classList.remove("hover:bg-secondary");
        this.classList.remove("hover:text-white");

        var keyword = this.getAttribute("data-target");
        if (keyword) {
          shuffleInstance.filter(keyword);
        }
      });
    });
  });
</script>
