---
import Counter from "@/components/functional-component/Counter";
import CuisineIcon from "@/components/functional-component/CuisineIcon";
import DeliveryIcon from "@/components/functional-component/DeliveryIcon";
import OrderIcon from "@/components/functional-component/OrderIcon";
import VideoPlayer from "@/components/functional-component/VideoPlayer";
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import AboutSection from "@/partials/AboutSection.astro";
import Testimonial from "@/partials/Testimonial.astro";

const about = await getListPage("about", "-index");
if (about.data.draft) {
  return Astro.redirect("/404");
}
const {
  title,
  description,
  meta_title,
  media,
  image,
  key_benefits,
  information,
} = about.data;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <AboutSection />

  <!-- Video Section  -->
  <!-- bg-[url(/images/about/media.png)] -->
  <section
  <section
  style={`background-image: url('${media.image}'); background-position: left center;`}
  class="section min-h-[520px] bg-contain bg-center bg-no-repeat"
>
  
>
    
    <h2
      class="text-balance text-right text-white mt-8 max-w-[600px] ml-auto mr-10"
      set:html={markdownify(media.title)}
      data-aos="fade-up-sm"
      data-aos-delay="200"
    />
  </section>
  <!-- /Video Section  -->

  <!-- Key Benefits -->
  <section class="section-sm overflow-x-hidden">
    <div class="container">
      <div class="row g-5">
        {
          key_benefits.slice(0, 3).map((benefit, index) => {
            return (
              <div
                class="sm:col-6 md:col-4"
                data-aos="fade-right-sm"
                data-aos-delay={index * 150}
              >
                <div class="flex gap-4">
                  {benefit.icon ? (
                    <div class="p-2 w-12 h-12 rounded-full bg-primary/5 shrink-0">
                      <DynamicIcon
                        icon={benefit.icon}
                        className="text-3xl text-primary"
                      />
                    </div>
                  ) : index === 0 ? (
                    <CuisineIcon />
                  ) : index === 1 ? (
                    <OrderIcon />
                  ) : index === 2 ? (
                    <DeliveryIcon />
                  ) : (
                    <span class="w-12 h-12 shrink-0 flex items-center justify-center">
                      Icon not found
                    </span>
                  )}
                  <div>
                    <h3
                      class="text-lg font-bold font-primary"
                      set:html={markdownify(benefit.title)}
                    />
                    <p
                      class="text-text/80 text-balance text-sm mt-3"
                      set:html={markdownify(benefit.description)}
                    />
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>
  <!-- /Key Benefits -->

  <!-- Info Section  -->
  <section class="section bg-primary/5 overflow-x-hidden">
    <div class="container">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-28 items-center">
        <div class="order-2 lg:order-1 max-lg:text-center">
          <h2
            set:html={markdownify(information.title)}
            data-aos="fade-up-sm"
            data-aos-delay="100"
          />
          <p
            class="text-xl text-text/90 mt-4 text-balance"
            set:html={markdownify(information.description)}
            data-aos="fade-up-sm"
            data-aos-delay="150"
          />
<a
  href="https://www.google.com/maps/place/lilycake/@25.7440295,-100.386257,3a,75y,236.78h,80.69t/data=!3m7!1e1!3m5!1sekQnSr7qw90fq2VXoks-VA!2e0!6shttps:%2F%2Fstreetviewpixels-pa.googleapis.com%2Fv1%2Fthumbnail%3Fcb_client%3Dmaps_sv.tactile%26w%3D900%26h%3D600%26pitch%3D9.310000000000002%26panoid%3DekQnSr7qw90fq2VXoks-VA%26yaw%3D236.78!7i16384!8i8192!4m7!3m6!1s0x866297b362a48a7b:0x27fc3c2d8f698126!8m2!3d25.7439747!4d-100.3863878!10e5!16s%2Fg%2F11nk7lf3hs?entry=ttu&g_ep=EgoyMDI2MDYwMS4wIKXMDSoASAFQAw%3D%3D"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-block mt-6 px-6 py-3 bg-white text-pink-600 rounded-lg font-semibold hover:bg-gray-100"
>
  📍 Ver ubicación en Google Maps
</a>
          <div class="grid sm:grid-cols-2 gap-5 mt-14">
            {
              information?.metrics?.map((metric, i) => {
                return (
                  <div
                    class="border border-border rounded-lg bg-white px-10 py-8 text-center"
                    data-aos="fade-up-sm"
                    data-aos-delay={i * 150}
                  >
                    <h3 class="h2">
                      <Counter
                        client:only="react"
                        count={metric.counter.count}
                        suffix={metric.counter.count_suffix}
                        prefix={metric.counter.count_prefix}
                        duration={metric.counter.count_duration}
                      />
                    </h3>
                    <p
                      class="text-primary mt-2"
                      set:html={markdownify(metric.name)}
                    />
                  </div>
                );
              })
            }
          </div>
        </div>
        <div
          data-aos="fade-left-sm"
          data-aos-delay="200"
          class="order-1 lg:order-2 w-full"
        >
          <ImageMod
            src="/images/about/local.png"
            alt={information.title}
            width={700}
            height={800}
            class="rounded-lg object-cover w-[650px] h-[380px] lg:w-[650px] max-lg:mx-auto"
          />
        </div>
      </div>
    </div>
  </section>
  <!-- /Info Section  -->

  <Testimonial />
</Base>
