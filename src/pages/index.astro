---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import AboutSection from "@/partials/AboutSection.astro";
import Testimonial from "@/partials/Testimonial.astro";
import Button from "@/shortcodes/Button";

const homepage = await getListPage("homepage", "-index");

const { hero, explore_menu, services, features } = homepage.data;
---

<Base>
  <!-- Banner -->
  <section
    class="section lg:h-[85vh]"
    style={`background-image: url('${hero.image}'); background-size: cover; background-position: center;`}
  >
    <div class="container relative md:w-[700px] md:mt-[9vh]">
      <h1
        class="text-[51px] lg:text-[72px] xl:text-[100px] leading-[49px] lg:leading-[96px] font-normal mb-8 text-center text-balance"
        set:html={markdownify(hero.title)}
        data-aos="fade-up-sm"
        data-aos-delay="100"
      />

      <p
        set:html={markdownify(hero.subtitle)}
        class="text-lg text-text/90 leading-8 mb-10 text-center text-balance"
        data-aos="fade-up-sm"
        data-aos-delay="25"
      />

      <div
        class="flex flex-col md:flex-row justify-center items-center gap-4"
        data-aos="zoom-in-sm"
        data-aos-delay={"200"}
      >
        {
          hero.buttons.map(
            (b, i: number) =>
              b.enable && (
                <Button
                  link={b.link}
                  label={b.label}
                  className="w-fit"
                  variant={i % 2 === 0 ? "solid" : "outline"}
                  icon={b?.icon}
                />
              )
          )
        }
      </div>
    </div>
  </section>
  <!-- /Banner -->

  <!-- Explore Menu -->
  {
    explore_menu.enable && (
      <section class="section">
        <div class="container">
          <h2
            class="text-center mb-14"
            set:html={markdownify(explore_menu.title)}
            data-aos="fade-up-sm"
            data-aos-delay="100"
          />

          <div class="row justify-center g-4">
            {explore_menu.items.map((item, i: number) => (
              <div class="col-10 md:col-6 lg:col-3">
                <div
                  data-aos="fade-up-sm"
                  data-aos-delay={100 + i * 50}
                  class="border border-border rounded-[1.125rem] py-10 px-8 flex flex-col items-center justify-center text-center group"
                >
                 <div class="overflow-hidden rounded-xl mb-6">
  <img
  src={item.image}
  alt={item.name}
  class="w-[180px] h-auto mx-auto object-contain rounded-xl"
/>
                  </div>

                  <h3
                    class="h6 font-semibold font-primary mb-4"
                    set:html={markdownify(item.name)}
                  />
                  <p
                    class="text-text/90 mb-9 text-sm"
                    set:html={markdownify(item.description)}
                  />

                  {item.button?.enable && (
                    <a
                      href={item.button.link}
                      class="text-secondary text-sm font-semibold hover:underline"
                    >
                      {item.button.label}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }
  <!-- /Explore Menu -->

  <AboutSection />

  <!-- Services -->
  {
    services.enable && (
      <section class="section">
        <div class="container">
          <h2
            class="mb-14 max-md:text-center"
            data-aos="fade-up-sm"
            data-aos-delay="100"
            set:html={markdownify(services.title)}
          />

          <div class="row justify-center g-4">
            {services.items.map((item, i: number) => (
              <div class="col-10 md:col-6 lg:col-3">
                <div
                  data-aos="fade-up-sm"
                  data-aos-delay={100 + i * 50}
                  class="group"
                >
                  <div class="overflow-hidden rounded-xl mb-3">
                    <ImageMod
                      src={item.image}
                      alt={item.name}
                      width={500}
                      height={320}
                      class="service-img"
                      
                    />
                    
                  </div>

                  <h3
                    class="text-2x1 font-semibold font-primary mb-4 px-3 text-white"
                    set:html={markdownify(item.name)}
                  />
                  <p
                    class="text-white mb-9 text-lg px-3 font-semibold"
                    set:html={markdownify(item.description)}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
    }
  
  <!-- /Services -->

  <!-- Features -->
  
    {features.enable && (
      <section class="section bg-primary/5">
        <div class="container">
          <div class="row justify-center">
            <div class="max-md:col-10">
              <div class="flex flex-col lg:flex-row justify-between gap-20 lg:gap-16 items-center">

                <div class="lg:w-[58%] pb-10">
                  <div class="flex gap-5">
                    <ImageMod
                      src={features.images[0]}
                      alt="about image"
                      width={427}
                      height={595}
                      class="rounded-lg w-[60%] h-[595px] object-cover overflow-hidden"
                      data-aos="zoom-in-sm"
                    />

                    <div class="flex flex-col gap-5 w-[45%] translate-y-10">
                      <ImageMod
                        src={features.images[1]}
                        alt="about image"
                        width={300}
                        height={330}
                        class="rounded-lg h-[330px] object-cover overflow-hidden"
                        data-aos="zoom-in-sm"
                      />
                      <ImageMod
                        src={features.images[2]}
                        alt="about image"
                        width={300}
                        height={240}
                        class="rounded-lg h-[238px] object-cover overflow-hidden"
                        data-aos="zoom-in-sm"
                      />
                    </div>
                  </div>
                </div>

                <div class="lg:w-[37%] lg:mt-10">
                  <h2
                    class="text-h3 md:text-h2 text-balance mb-7 text-left"
                    data-aos="fade-up-sm"
                    data-aos-delay="50"
                    set:html={markdownify(features.title)}
                  />

                  {features.content && (
                    <p
                      set:html={markdownify(features.content)}
                      class="mb-12 text-left text-sm text-balance"
                      data-aos="fade-up-sm"
                      data-aos-delay="100"
                    />
                  )}

                  {features.key_benefits.map((benefit, i: number) => (
                    <div
                      class="flex items-start gap-4 mb-4"
                      data-aos="fade-up-sm"
                      data-aos-delay={150 + i * 50}
                    >
                      <span class="p-1.5 bg-secondary rounded-full inline-flex items-center justify-center">
                        <DynamicIcon
                          icon={benefit.icon}
                          className="text-white shrink-0 text-xs"
                        />
                      </span>

                      <p
                        set:html={markdownify(benefit.benefit)}
                        class="text-text/90 font-medium text-lg"
                      />
                    </div>
                  ))}
                </div>

              </div>
            </div>
          </div>
        </div>
      </section>
    )}
    
  
  <!-- /Features -->

  <Testimonial />
</Base>

